generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  passwordHash     String
  bridgeCustomerId String?  @unique
  kycStatus        String   @default("none")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
