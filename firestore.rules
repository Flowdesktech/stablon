rules_version = '2';

// This app reads/writes Firestore exclusively through the Firebase Admin SDK on
// the server (which bypasses these rules). No client ever touches Firestore
// directly, so deny all direct client access as a hard safety boundary.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
